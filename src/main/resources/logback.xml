<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{tool:-sys}:%X{file:-global}] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDERR" />
    </root>

    <!-- Suppress noisy frameworks -->
    <logger name="io.modelcontextprotocol" level="WARN" />
    <logger name="org.openjdk.jmc" level="WARN" />
    <logger name="io.github.deplague" level="INFO" />
</configuration>
